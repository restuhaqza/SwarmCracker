# SwarmCracker Cluster — libvirt (KVM) Inventory
#
# Used with: ansible-playbook -i inventory/libvirt site.yml
# IPs are assigned by libvirt DHCP — update after `vagrant up`
#
# Network layout:
#   - eth0: vagrant-libvirt network (192.168.121.x) — SSH access
#   - eth1: swarmcracker network (192.168.122.x) — cluster communication
#
# Updated: 2026-05-02

[managers]
swarm-manager ansible_host=192.168.121.18 ansible_user=vagrant manager_ip=192.168.122.10

[workers]
swarm-worker-1 ansible_host=192.168.121.153 ansible_user=vagrant
swarm-worker-2 ansible_host=192.168.121.59 ansible_user=vagrant

[swarmcracker:children]
managers
workers

[swarmcracker:vars]
ansible_user=vagrant
ansible_become=yes
ansible_become_method=sudo
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
# Token must be obtained from manager: swarmctl cluster inspect default
worker_join_token=PLACEHOLDER_GET_TOKEN_FROM_MANAGER
worker_manager_host=192.168.121.18
worker_manager_port=4242