# SwarmCracker Manager Configuration
# Managed by Ansible - Do not edit manually

executor:
  kernel_path: {{ swarmcracker_kernel_path }}
  rootfs_dir: {{ swarmcracker_rootfs_dir }}
  default_vcpus: 2
  default_memory_mb: 1024
  reserved_cpus: {{ swarmcracker_reserved_cpus }}
  reserved_memory_mb: {{ swarmcracker_reserved_memory_mb }}

network:
  bridge_name: {{ swarmcracker_bridge_name }}
  subnet: {{ swarmcracker_subnet }}
  bridge_ip: {{ swarmcracker_bridge_ip }}
  ip_mode: {{ swarmcracker_ip_mode }}
  nat_enabled: {{ swarmcracker_nat_enabled }}
  vxlan_enabled: {{ swarmcracker_vxlan_enabled }}
  vxlan_vni: {{ swarmcracker_vxlan_vni }}
  vxlan_port: {{ swarmcracker_vxlan_port }}

manager:
  bind_address: {{ manager_bind_address }}
  port: {{ manager_port }}
  state_dir: {{ manager_state_dir }}

logging:
  level: {{ swarmcracker_log_level }}
  directory: {{ swarmcracker_log_dir }}

cleanup:
  enabled: {{ swarmcracker_auto_cleanup }}
  max_image_age_days: {{ swarmcracker_max_image_age_days }}
